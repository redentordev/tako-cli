# Environment Variables for Tako CLI
# Copy this file to .env and fill in your actual values

# REQUIRED: Your VPS server IP address
SERVER_HOST=YOUR_SERVER_IP

# REQUIRED: Registry credentials (example: GitHub Container Registry)
# Create a token with read:packages at https://github.com/settings/tokens
REGISTRY_USER=YOUR_GITHUB_USERNAME
REGISTRY_TOKEN=YOUR_TOKEN_WITH_READ_PACKAGES
