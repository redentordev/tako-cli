# Shared values used by the deployment pattern templates.
#
# These examples are intentionally environment-driven so the same template can
# be copied into a real app without editing secrets or host-specific values
# into tako.yaml.

# VPS IP address or hostname.
SERVER_HOST=203.0.113.10

# CI/CD examples use the TAKO_* names to match GitHub Actions secrets.
TAKO_SERVER_HOST=203.0.113.10

# SSH key used by local examples.
SSH_KEY=~/.ssh/id_ed25519

# SSH key path restored by CI examples.
TAKO_SSH_KEY=~/.ssh/tako_deploy

# Email used for Let's Encrypt certificates.
LETSENCRYPT_EMAIL=ops@example.com

# Stateful examples need a real password before deployment.
POSTGRES_PASSWORD=replace-with-a-strong-password
