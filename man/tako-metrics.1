.nh
.TH "TAKO" "1" "Jun 2026" "Tako CLI" "Tako CLI Manual"

.SH NAME
tako-metrics - View system metrics from servers


.SH SYNOPSIS
\fBtako metrics [flags]\fP


.SH DESCRIPTION
Display real-time system metrics (CPU, RAM, Disk) collected from deployed servers.

.PP
The monitoring agent runs continuously on each server, collecting metrics every 60 seconds.
This command fetches and displays the latest metrics.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for metrics

.PP
\fB--live\fP[=false]
	Continuous live updates

.PP
\fB--once\fP[=false]
	Collect metrics once immediately

.PP
\fB-s\fP, \fB--server\fP=""
	Specific server to monitor


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	config file (default is ./tako.yaml or ./tako.json)

.PP
\fB-e\fP, \fB--env\fP=""
	environment to deploy (default: production or only environment)

.PP
\fB--events\fP=""
	stream progress events to stdout: ndjson (human output moves to stderr)

.PP
\fB--host-key-mode\fP=""
	SSH host key verification mode: tofu, strict, ask (default: tofu)

.PP
\fB--output\fP="text"
	output format: text or json (json reserves stdout for the final result document)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH SEE ALSO
\fBtako(1)\fP
