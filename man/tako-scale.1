.TH "TAKO" "1" "Jun 2026" "Tako CLI" "Tako CLI Manual"

.SH NAME
tako-scale - Scale takod services to specified replicas


.SH SYNOPSIS
\fBtako scale SERVICE=REPLICAS [SERVICE=REPLICAS...] [flags]\fP


.SH DESCRIPTION
Scale one or more services to a specified number of replicas.

.PP
This command reconciles running takod containers without rebuilding images.

.PP
Examples:
  tako scale web=5
  tako scale api=3 web=2
  tako scale worker=10
  tako scale web=0

.PP
Note: this changes runtime state immediately. Update replicas in tako.yaml if
you want the next full deploy to preserve the same count.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for scale


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	config file (default is ./tako.yaml or ./tako.json)

.PP
\fB-e\fP, \fB--env\fP=""
	environment to deploy (default: production or only environment)

.PP
\fB--host-key-mode\fP=""
	SSH host key verification mode: tofu, strict, ask (default: tofu)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH SEE ALSO
\fBtako(1)\fP
