.nh
.TH "TAKO" "1" "Jun 2026" "Tako CLI" "Tako CLI Manual"

.SH NAME
tako-platform-controller-promotion-verify - Verify a cold recovery tree can restore the single controller


.SH SYNOPSIS
\fBtako platform controller promotion verify [flags]\fP


.SH DESCRIPTION
Verify a cold recovery tree can restore the single controller


.SH OPTIONS
\fB--cluster-id\fP=""
	Expected immutable cluster UUID

.PP
\fB--controller-key-sha256\fP=""
	Externally recorded controller recovery-key fingerprint

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for verify

.PP
\fB--staged-root\fP=""
	Authenticated recovery staging root


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	config file (default is ./tako.yaml or ./tako.json)

.PP
\fB-e\fP, \fB--env\fP=""
	environment to deploy (default: production or only environment)

.PP
\fB--events\fP=""
	stream progress events to stdout: ndjson (human output moves to stderr)

.PP
\fB--host-key-mode\fP=""
	SSH host key verification mode: tofu, strict, ask (default: tofu)

.PP
\fB--output\fP="text"
	output format: text or json (json reserves stdout for the final result document)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH SEE ALSO
\fBtako-platform-controller-promotion(1)\fP
