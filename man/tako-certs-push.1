.nh
.TH "TAKO" "1" "Jun 2026" "Tako CLI" "Tako CLI Manual"

.SH NAME
tako-certs-push - Validate and push a certificate/key pair to proxy nodes


.SH SYNOPSIS
\fBtako certs push DOMAIN [flags]\fP


.SH DESCRIPTION
Validate and push a certificate/key pair to proxy nodes


.SH OPTIONS
\fB--cert\fP=""
	Certificate PEM file, including intermediates

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for push

.PP
\fB--key\fP=""
	Private key PEM file

.PP
\fB-s\fP, \fB--server\fP=""
	Target one environment proxy node (default: all proxy nodes)


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	config file (default is ./tako.yaml or ./tako.json)

.PP
\fB-e\fP, \fB--env\fP=""
	environment to deploy (default: production or only environment)

.PP
\fB--events\fP=""
	stream progress events to stdout: ndjson (human output moves to stderr)

.PP
\fB--host-key-mode\fP=""
	SSH host key verification mode: tofu, strict, ask (default: tofu)

.PP
\fB--output\fP="text"
	output format: text or json (json reserves stdout for the final result document)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH SEE ALSO
\fBtako-certs(1)\fP
