.nh
.TH "TAKO" "1" "Jun 2026" "Tako CLI" "Tako CLI Manual"

.SH NAME
tako-secrets-import - Import provider secrets into encrypted Tako secrets


.SH SYNOPSIS
\fBtako secrets import PROVIDER [NAME...] [flags]\fP


.SH DESCRIPTION
Import external provider secrets into encrypted .tako/secrets files.

.PP
By default this command performs a redacted dry run. Pass --write to persist
the imported values. Existing local secrets are skipped unless --overwrite is
provided.


.SH OPTIONS
\fB--debug-show-values\fP[=false]
	Print plaintext secret values

.PP
\fB--dry-run\fP[=false]
	Preview provider import without writing

.PP
\fB-e\fP, \fB--env\fP=""
	Environment (e.g., production, staging)

.PP
\fB--from\fP=""
	Provider folder/name prefix for explicit names

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for import

.PP
\fB--map\fP=[]
	Map provider source to local secret key (SOURCE=DEST)

.PP
\fB--overwrite\fP[=false]
	Overwrite existing local secrets

.PP
\fB--path\fP=""
	Provider path/prefix to import recursively

.PP
\fB--prefix-strip\fP=""
	Strip this provider prefix before deriving local secret keys

.PP
\fB--profile\fP=""
	AWS CLI profile

.PP
\fB--region\fP=""
	AWS region

.PP
\fB--write\fP[=false]
	Write imported secrets to encrypted .tako/secrets files


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	config file (default is ./tako.yaml or ./tako.json)

.PP
\fB--events\fP=""
	stream progress events to stdout: ndjson (human output moves to stderr)

.PP
\fB--host-key-mode\fP=""
	SSH host key verification mode: tofu, strict, ask (default: tofu)

.PP
\fB--output\fP="text"
	output format: text or json (json reserves stdout for the final result document)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH SEE ALSO
\fBtako-secrets(1)\fP
