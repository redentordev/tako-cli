.nh
.TH "TAKO" "1" "Jun 2026" "Tako CLI" "Tako CLI Manual"

.SH NAME
tako-platform-backup - Create and verify external platform recovery bundles


.SH SYNOPSIS
\fBtako platform backup [flags]\fP


.SH DESCRIPTION
Create and verify external platform recovery bundles


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for backup


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	config file (default is ./tako.yaml or ./tako.json)

.PP
\fB-e\fP, \fB--env\fP=""
	environment to deploy (default: production or only environment)

.PP
\fB--events\fP=""
	stream progress events to stdout: ndjson (human output moves to stderr)

.PP
\fB--host-key-mode\fP=""
	SSH host key verification mode: tofu, strict, ask (default: tofu)

.PP
\fB--output\fP="text"
	output format: text or json (json reserves stdout for the final result document)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH SEE ALSO
\fBtako-platform(1)\fP, \fBtako-platform-backup-create(1)\fP, \fBtako-platform-backup-restore(1)\fP, \fBtako-platform-backup-verify(1)\fP
