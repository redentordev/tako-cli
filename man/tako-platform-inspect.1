.nh
.TH "TAKO" "1" "Jun 2026" "Tako CLI" "Tako CLI Manual"

.SH NAME
tako-platform-inspect - Explain this server's existing platform enrollment and control authority


.SH SYNOPSIS
\fBtako platform inspect [flags]\fP


.SH DESCRIPTION
Explain this server's existing platform enrollment and control authority


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for inspect

.PP
\fB--identity-file\fP="/etc/tako/identity.json"
	Protected create-once installation identity

.PP
\fB--inventory\fP="/etc/tako/cluster-inventory.json"
	Root-published trusted cluster inventory

.PP
\fB--local-binding\fP="/etc/tako/local-node.json"
	Root-published public local-node binding

.PP
\fB--membership\fP="/var/lib/tako/control/membership.json"
	Protected controller membership state

.PP
\fB--mesh-key-dir\fP="/etc/tako/wireguard"
	Protected platform WireGuard identity directory

.PP
\fB--platform-config\fP="/etc/tako/platform.json"
	Protected controller platform configuration

.PP
\fB--worker-unit\fP="/etc/systemd/system/tako-platform-worker.service"
	Installed controller worker service unit


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	config file (default is ./tako.yaml or ./tako.json)

.PP
\fB-e\fP, \fB--env\fP=""
	environment to deploy (default: production or only environment)

.PP
\fB--events\fP=""
	stream progress events to stdout: ndjson (human output moves to stderr)

.PP
\fB--host-key-mode\fP=""
	SSH host key verification mode: tofu, strict, ask (default: tofu)

.PP
\fB--output\fP="text"
	output format: text or json (json reserves stdout for the final result document)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH SEE ALSO
\fBtako-platform(1)\fP
