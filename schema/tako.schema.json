{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/redentordev/tako-cli/schema/tako.schema.json",
  "title": "Tako CLI Configuration",
  "description": "Configuration schema for Tako CLI (tako.yaml or tako.json)",
  "type": "object",
  "required": [
    "project",
    "servers",
    "environments"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for IDE support"
    },
    "project": {
      "type": "object",
      "description": "Project metadata",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "App namespace. Keep this stable and unique per product on shared nodes.",
          "pattern": "^[a-z][a-z0-9-]{0,62}$"
        },
        "version": {
          "type": "string",
          "description": "Project version (semver recommended)"
        }
      }
    },
    "runtime": {
      "type": "object",
      "description": "takod mesh runtime settings. One node and many nodes use the same runtime model.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "takod"
          ],
          "default": "takod",
          "description": "Runtime engine"
        },
        "agent": {
          "type": "object",
          "description": "takod node-local reconciler settings",
          "properties": {
            "enabled": {
              "type": "boolean",
              "const": true,
              "default": true,
              "description": "Must be true; takod agent is required"
            },
            "socket": {
              "type": "string",
              "default": "/run/tako/takod.sock"
            },
            "dataDir": {
              "type": "string",
              "default": "/var/lib/tako"
            }
          }
        }
      }
    },
    "mesh": {
      "type": "object",
      "description": "Private WireGuard-style node mesh settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "const": true,
          "default": true,
          "description": "Must be true; single-node deploys use a one-node mesh"
        },
        "networkCIDR": {
          "type": "string",
          "default": "10.210.0.0/16"
        },
        "interface": {
          "type": "string",
          "default": "tako"
        },
        "listenPort": {
          "type": "integer",
          "default": 51820,
          "minimum": 1,
          "maximum": 65535
        },
        "subnetBits": {
          "type": "integer",
          "default": 24,
          "minimum": 8,
          "maximum": 30
        },
        "natTraversal": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "state": {
      "type": "object",
      "description": "Deployment state and reconciliation policy",
      "properties": {
        "backend": {
          "type": "string",
          "enum": [
            "replicated"
          ],
          "default": "replicated"
        },
        "deployConsistency": {
          "type": "string",
          "enum": [
            "lease"
          ],
          "default": "lease"
        },
        "onUnreachableNode": {
          "type": "string",
          "enum": [
            "block"
          ],
          "default": "block"
        },
        "remoteCacheEnabled": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "servers": {
      "type": "object",
      "description": "Explicit SSH server connection details",
      "additionalProperties": {
        "type": "object",
        "required": [
          "host",
          "user"
        ],
        "properties": {
          "host": {
            "type": "string",
            "description": "Server IP or hostname"
          },
          "user": {
            "type": "string",
            "description": "SSH user"
          },
          "port": {
            "type": "integer",
            "description": "SSH port",
            "default": 22
          },
          "sshKey": {
            "type": "string",
            "description": "Path to SSH private key"
          },
          "password": {
            "type": "string",
            "description": "SSH password (use env var)"
          },
          "labels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    "deployment": {
      "type": "object",
      "description": "Deployment optimization settings",
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "parallel",
            "sequential"
          ],
          "description": "Deployment strategy"
        },
        "source": {
          "type": "string",
          "enum": [
            "local",
            "git"
          ],
          "default": "local",
          "description": "Build source mode: local worktree or committed git HEAD"
        },
        "parallel": {
          "type": "object",
          "properties": {
            "maxConcurrentBuilds": {
              "type": "integer",
              "default": 4
            },
            "maxConcurrentDeploys": {
              "type": "integer",
              "default": 4
            },
            "strategy": {
              "type": "string",
              "enum": [
                "dependency-aware",
                "resource-aware",
                "round-robin"
              ]
            }
          }
        },
        "cache": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "type": {
              "type": "string",
              "enum": [
                "local",
                "registry"
              ]
            },
            "retention": {
              "type": "string",
              "description": "Cache retention period (e.g., 7d)"
            },
            "ref": {
              "type": "string",
              "description": "Registry cache reference for type=registry"
            },
            "builder": {
              "type": "string",
              "description": "Optional docker buildx builder name"
            }
          }
        }
      }
    },
    "notifications": {
      "type": "object",
      "description": "Deployment notification settings",
      "properties": {
        "slack": {
          "type": "string",
          "description": "Slack webhook URL"
        },
        "discord": {
          "type": "string",
          "description": "Discord webhook URL"
        },
        "webhook": {
          "type": "string",
          "description": "Generic webhook URL"
        }
      }
    },
    "registry": {
      "type": "object",
      "description": "Private registry credentials for prebuilt image pulls",
      "properties": {
        "url": {
          "type": "string",
          "description": "Registry host, e.g. ghcr.io or registry.example.com:5000"
        },
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string",
          "description": "Use an environment variable placeholder, e.g. ${REGISTRY_TOKEN}"
        },
        "identityToken": {
          "type": "string",
          "description": "Registry identity token alternative to username/password"
        }
      }
    },
    "volumes": {
      "type": "object",
      "description": "Named volume definitions",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "driver": {
            "type": "string",
            "default": "local"
          },
          "driver_opts": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "labels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "external": {
            "type": "boolean"
          },
          "replicated": {
            "type": "boolean",
            "description": "True when the application or external storage layer handles safe multi-node writes"
          },
          "name": {
            "type": "string"
          }
        }
      }
    },
    "configs": {
      "type": "object",
      "description": "Project-owned config artifacts mounted read-only into services",
      "additionalProperties": {
        "type": "object",
        "oneOf": [
          {
            "required": [
              "source"
            ]
          },
          {
            "required": [
              "generate"
            ]
          }
        ],
        "properties": {
          "source": {
            "type": "string",
            "description": "Relative local file path inside the project checkout"
          },
          "generate": {
            "type": "object",
            "description": "Generated config artifact definition",
            "properties": {
              "caddy": {
                "type": "object",
                "description": "Generate a Caddyfile from cross-project imports",
                "required": [
                  "email",
                  "adminHost",
                  "siteHost",
                  "adminImport",
                  "rendererImport"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "description": "Let's Encrypt account email"
                  },
                  "adminHost": {
                    "type": "string",
                    "description": "Static admin hostname"
                  },
                  "siteHost": {
                    "type": "string",
                    "description": "Static platform site hostname"
                  },
                  "adminImport": {
                    "type": "string",
                    "description": "Import alias for the admin upstream"
                  },
                  "rendererImport": {
                    "type": "string",
                    "description": "Import alias for the renderer upstream"
                  },
                  "askImport": {
                    "type": "string",
                    "description": "Import alias for the on-demand TLS ask endpoint; defaults to adminImport"
                  },
                  "askPath": {
                    "type": "string",
                    "description": "HTTP path for Caddy on-demand TLS ask checks"
                  },
                  "onDemandTLS": {
                    "type": "boolean",
                    "description": "Enable Caddy on-demand TLS catch-all routing"
                  }
                }
              }
            }
          }
        }
      }
    },
    "imports": {
      "type": "object",
      "description": "Cross-project service imports keyed by local alias",
      "additionalProperties": {
        "type": "object",
        "required": [
          "project",
          "environment",
          "service",
          "port"
        ],
        "properties": {
          "project": {
            "type": "string",
            "description": "Exporting project name"
          },
          "environment": {
            "type": "string",
            "description": "Exporting environment/stage"
          },
          "service": {
            "type": "string",
            "description": "Exporting service name"
          },
          "port": {
            "type": "string",
            "description": "Exported named port"
          },
          "servers": {
            "type": "array",
            "description": "Optional configured server names to query for the exported project",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "environments": {
      "type": "object",
      "description": "Deployment environments",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "servers": {
            "type": "array",
            "description": "Server names for this environment",
            "items": {
              "type": "string"
            }
          },
          "services": {
            "type": "object",
            "description": "Services to deploy",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "build": {
                  "type": "string",
                  "description": "Build context path"
                },
                "dockerfile": {
                  "type": "string",
                  "description": "Dockerfile path relative to the build context"
                },
                "image": {
                  "type": "string",
                  "description": "Docker image"
                },
                "platform": {
                  "type": "string",
                  "description": "Docker platform for service image builds",
                  "enum": [
                    "linux/amd64",
                    "linux/arm64",
                    "linux/arm/v6",
                    "linux/arm/v7",
                    "linux/386"
                  ]
                },
                "port": {
                  "type": "integer",
                  "description": "Container port shorthand for one HTTP/internal port"
                },
                "ports": {
                  "type": "array",
                  "description": "Named service ports for internal, proxy, or host binding",
                  "items": {
                    "type": "object",
                    "required": [
                      "name",
                      "target"
                    ],
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "target": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 65535
                      },
                      "published": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 65535
                      },
                      "protocol": {
                        "type": "string",
                        "enum": [
                          "http",
                          "https",
                          "tcp",
                          "udp"
                        ]
                      },
                      "mode": {
                        "type": "string",
                        "enum": [
                          "internal",
                          "proxy",
                          "host"
                        ]
                      },
                      "hostIP": {
                        "type": "string",
                        "description": "Host bind IP or CIDR for host mode"
                      },
                      "internal": {
                        "type": "boolean",
                        "description": "Compatibility shorthand for mode: internal"
                      },
                      "proxy": {
                        "type": "object",
                        "description": "Public proxy settings for this port",
                        "properties": {
                          "domain": {
                            "type": "string",
                            "description": "Primary domain"
                          },
                          "redirectFrom": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "description": "Domains to redirect from"
                          },
                          "email": {
                            "type": "string",
                            "description": "Let's Encrypt email"
                          },
                          "tls": {
                            "type": "object",
                            "properties": {
                              "provider": {
                                "type": "string",
                                "enum": [
                                  "letsencrypt",
                                  "zerossl"
                                ]
                              },
                              "staging": {
                                "type": "boolean"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "command": {
                  "type": "string",
                  "description": "Override container command"
                },
                "replicas": {
                  "type": "integer",
                  "default": 1,
                  "description": "Number of replicas"
                },
                "restart": {
                  "type": "string",
                  "enum": [
                    "no",
                    "on-failure",
                    "always",
                    "unless-stopped"
                  ],
                  "description": "Restart policy"
                },
                "env": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  },
                  "description": "Environment variables"
                },
                "envFile": {
                  "type": "string",
                  "description": "Path to .env file"
                },
                "secrets": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Secret names from .tako/secrets"
                },
                "volumes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Volume mounts"
                },
                "configs": {
                  "type": "array",
                  "description": "Read-only config file mounts from top-level configs",
                  "items": {
                    "type": "object",
                    "required": [
                      "source",
                      "target"
                    ],
                    "properties": {
                      "source": {
                        "type": "string",
                        "description": "Top-level config artifact name"
                      },
                      "target": {
                        "type": "string",
                        "description": "Absolute container file path"
                      },
                      "mode": {
                        "type": "string",
                        "description": "Read-only octal file mode, e.g. 0444"
                      }
                    }
                  }
                },
                "persistent": {
                  "type": "boolean",
                  "description": "Mark as persistent (databases, caches)"
                },
                "dependsOn": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Service dependencies"
                },
                "proxy": {
                  "type": "object",
                  "description": "Public proxy settings",
                  "properties": {
                    "domain": {
                      "type": "string",
                      "description": "Primary domain"
                    },
                    "redirectFrom": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Domains to redirect from"
                    },
                    "email": {
                      "type": "string",
                      "description": "Let's Encrypt email"
                    },
                    "tls": {
                      "type": "object",
                      "properties": {
                        "provider": {
                          "type": "string",
                          "enum": [
                            "letsencrypt",
                            "zerossl"
                          ]
                        },
                        "staging": {
                          "type": "boolean"
                        }
                      }
                    }
                  }
                },
                "healthCheck": {
                  "type": "object",
                  "description": "Health check configuration",
                  "properties": {
                    "path": {
                      "type": "string"
                    },
                    "interval": {
                      "type": "string"
                    },
                    "timeout": {
                      "type": "string"
                    },
                    "retries": {
                      "type": "integer"
                    },
                    "startPeriod": {
                      "type": "string"
                    }
                  }
                },
                "deploy": {
                  "type": "object",
                  "description": "Deployment strategy for takod reconciliation",
                  "properties": {
                    "strategy": {
                      "type": "string",
                      "enum": [
                        "recreate",
                        "rolling"
                      ]
                    },
                    "order": {
                      "type": "string",
                      "enum": [
                        "start-first",
                        "stop-first"
                      ]
                    },
                    "maxUnavailable": {
                      "type": "integer"
                    },
                    "monitor": {
                      "type": "string"
                    }
                  }
                },
                "placement": {
                  "type": "object",
                  "description": "Placement configuration",
                  "properties": {
                    "strategy": {
                      "type": "string",
                      "enum": [
                        "spread",
                        "pinned",
                        "any",
                        "global"
                      ]
                    },
                    "servers": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "constraints": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "loadBalancer": {
                  "type": "object",
                  "description": "Load balancer settings",
                  "properties": {
                    "strategy": {
                      "type": "string",
                      "enum": [
                        "round_robin",
                        "least_conn",
                        "ip_hash",
                        "random"
                      ]
                    }
                  }
                },
                "export": {
                  "type": "object",
                  "description": "Explicit service ports exported to other projects",
                  "required": [
                    "ports"
                  ],
                  "properties": {
                    "ports": {
                      "type": "object",
                      "description": "Exported port aliases mapped to container target ports",
                      "additionalProperties": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 65535
                      }
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    }
  }
}
