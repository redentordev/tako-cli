{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/redentordev/tako-cli/schema/tako.schema.json",
  "title": "Tako CLI Configuration",
  "description": "Configuration schema for Tako CLI (tako.yaml or tako.json)",
  "type": "object",
  "required": [
    "project",
    "servers",
    "environments"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for IDE support"
    },
    "project": {
      "type": "object",
      "description": "Project metadata",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Project name (lowercase, alphanumeric, hyphens)",
          "pattern": "^[a-z][a-z0-9-]{0,62}$"
        },
        "version": {
          "type": "string",
          "description": "Project version (semver recommended)"
        }
      }
    },
    "runtime": {
      "type": "object",
      "description": "takod mesh runtime settings. One node and many nodes use the same runtime model.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "takod"
          ],
          "default": "takod",
          "description": "Runtime engine"
        },
        "agent": {
          "type": "object",
          "description": "takod node-local reconciler settings",
          "properties": {
            "enabled": {
              "type": "boolean",
              "const": true,
              "default": true,
              "description": "Must be true; takod agent is required"
            },
            "socket": {
              "type": "string",
              "default": "/run/tako/takod.sock"
            },
            "dataDir": {
              "type": "string",
              "default": "/var/lib/tako"
            }
          }
        }
      }
    },
    "mesh": {
      "type": "object",
      "description": "Private WireGuard-style node mesh settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "const": true,
          "default": true,
          "description": "Must be true; single-node deploys use a one-node mesh"
        },
        "networkCIDR": {
          "type": "string",
          "default": "10.210.0.0/16"
        },
        "interface": {
          "type": "string",
          "default": "tako"
        },
        "listenPort": {
          "type": "integer",
          "default": 51820,
          "minimum": 1,
          "maximum": 65535
        },
        "subnetBits": {
          "type": "integer",
          "default": 24,
          "minimum": 8,
          "maximum": 30
        },
        "natTraversal": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "state": {
      "type": "object",
      "description": "Deployment state and reconciliation policy",
      "properties": {
        "backend": {
          "type": "string",
          "enum": [
            "replicated"
          ],
          "default": "replicated"
        },
        "deployConsistency": {
          "type": "string",
          "enum": [
            "lease"
          ],
          "default": "lease"
        },
        "onUnreachableNode": {
          "type": "string",
          "enum": [
            "block"
          ],
          "default": "block"
        },
        "remoteCacheEnabled": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "servers": {
      "type": "object",
      "description": "Explicit SSH server connection details",
      "additionalProperties": {
        "type": "object",
        "required": [
          "host",
          "user"
        ],
        "properties": {
          "host": {
            "type": "string",
            "description": "Server IP or hostname"
          },
          "user": {
            "type": "string",
            "description": "SSH user"
          },
          "port": {
            "type": "integer",
            "description": "SSH port",
            "default": 22
          },
          "sshKey": {
            "type": "string",
            "description": "Path to SSH private key"
          },
          "password": {
            "type": "string",
            "description": "SSH password (use env var)"
          },
          "labels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    "deployment": {
      "type": "object",
      "description": "Deployment optimization settings",
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "parallel",
            "sequential"
          ],
          "description": "Deployment strategy"
        },
        "parallel": {
          "type": "object",
          "properties": {
            "maxConcurrentBuilds": {
              "type": "integer",
              "default": 4
            },
            "maxConcurrentDeploys": {
              "type": "integer",
              "default": 4
            },
            "strategy": {
              "type": "string",
              "enum": [
                "dependency-aware",
                "resource-aware",
                "round-robin"
              ]
            }
          }
        },
        "cache": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "type": {
              "type": "string",
              "enum": [
                "local",
                "registry"
              ]
            },
            "retention": {
              "type": "string",
              "description": "Cache retention period (e.g., 7d)"
            }
          }
        }
      }
    },
    "notifications": {
      "type": "object",
      "description": "Deployment notification settings",
      "properties": {
        "slack": {
          "type": "string",
          "description": "Slack webhook URL"
        },
        "discord": {
          "type": "string",
          "description": "Discord webhook URL"
        },
        "webhook": {
          "type": "string",
          "description": "Generic webhook URL"
        }
      }
    },
    "volumes": {
      "type": "object",
      "description": "Named volume definitions",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "driver": {
            "type": "string",
            "default": "local"
          },
          "driver_opts": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "labels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "external": {
            "type": "boolean"
          },
          "name": {
            "type": "string"
          }
        }
      }
    },
    "environments": {
      "type": "object",
      "description": "Deployment environments",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "servers": {
            "type": "array",
            "description": "Server names for this environment",
            "items": {
              "type": "string"
            }
          },
          "services": {
            "type": "object",
            "description": "Services to deploy",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "build": {
                  "type": "string",
                  "description": "Build context path"
                },
                "image": {
                  "type": "string",
                  "description": "Docker image"
                },
                "port": {
                  "type": "integer",
                  "description": "Container port"
                },
                "command": {
                  "type": "string",
                  "description": "Override container command"
                },
                "replicas": {
                  "type": "integer",
                  "default": 1,
                  "description": "Number of replicas"
                },
                "restart": {
                  "type": "string",
                  "enum": [
                    "no",
                    "on-failure",
                    "always",
                    "unless-stopped"
                  ],
                  "description": "Restart policy"
                },
                "env": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  },
                  "description": "Environment variables"
                },
                "envFile": {
                  "type": "string",
                  "description": "Path to .env file"
                },
                "secrets": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Secret names from .tako/secrets"
                },
                "volumes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Volume mounts"
                },
                "persistent": {
                  "type": "boolean",
                  "description": "Mark as persistent (databases, caches)"
                },
                "dependsOn": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Service dependencies"
                },
                "proxy": {
                  "type": "object",
                  "description": "Public proxy settings",
                  "properties": {
                    "domain": {
                      "type": "string",
                      "description": "Primary domain"
                    },
                    "redirectFrom": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Domains to redirect from"
                    },
                    "email": {
                      "type": "string",
                      "description": "Let's Encrypt email"
                    },
                    "tls": {
                      "type": "object",
                      "properties": {
                        "provider": {
                          "type": "string",
                          "enum": [
                            "letsencrypt",
                            "zerossl"
                          ]
                        },
                        "staging": {
                          "type": "boolean"
                        }
                      }
                    }
                  }
                },
                "healthCheck": {
                  "type": "object",
                  "description": "Health check configuration",
                  "properties": {
                    "path": {
                      "type": "string"
                    },
                    "interval": {
                      "type": "string"
                    },
                    "timeout": {
                      "type": "string"
                    },
                    "retries": {
                      "type": "integer"
                    },
                    "startPeriod": {
                      "type": "string"
                    }
                  }
                },
                "deploy": {
                  "type": "object",
                  "description": "Deployment strategy for takod reconciliation",
                  "properties": {
                    "strategy": {
                      "type": "string",
                      "enum": [
                        "recreate"
                      ]
                    },
                    "maxUnavailable": {
                      "type": "integer"
                    }
                  }
                },
                "placement": {
                  "type": "object",
                  "description": "Placement configuration",
                  "properties": {
                    "strategy": {
                      "type": "string",
                      "enum": [
                        "spread",
                        "pinned",
                        "any",
                        "global"
                      ]
                    },
                    "servers": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "constraints": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "loadBalancer": {
                  "type": "object",
                  "description": "Load balancer settings",
                  "properties": {
                    "strategy": {
                      "type": "string",
                      "enum": [
                        "round_robin",
                        "least_conn",
                        "ip_hash",
                        "random"
                      ]
                    }
                  }
                },
                "export": {
                  "type": "boolean",
                  "description": "Export service to other projects"
                },
                "imports": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Import services from other projects"
                }
              }
            }
          }
        }
      }
    }
  }
}
