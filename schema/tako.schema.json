{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/redentordev/tako-cli/schema/tako.schema.json",
  "title": "Tako CLI Configuration",
  "description": "Configuration schema for Tako CLI (tako.yaml or tako.json)",
  "type": "object",
  "required": [
    "project",
    "servers",
    "environments"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for IDE support"
    },
    "project": {
      "type": "object",
      "description": "Project metadata",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "App namespace. Keep this stable and unique per product on shared nodes.",
          "pattern": "^[a-z][a-z0-9-]{0,62}$"
        },
        "version": {
          "type": "string",
          "description": "Project metadata version. Build-backed deploy artifacts are tagged by Git commit; this does not need to change to redeploy."
        }
      }
    },
    "builds": {
      "type": "object",
      "description": "Reusable image builds referenced by services through imageFrom.",
      "propertyNames": { "pattern": "^[a-z][a-z0-9_-]{0,62}$" },
      "additionalProperties": {
        "type": "object",
        "required": ["context"],
        "additionalProperties": false,
        "properties": {
          "context": { "type": "string", "minLength": 1 },
          "args": {
            "type": "object",
            "maxProperties": 128,
            "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
            "additionalProperties": { "type": "string" }
          },
          "target": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$" },
          "dockerfile": { "type": "string", "minLength": 1 }
        }
      }
    },
    "runtime": {
      "type": "object",
      "description": "takod mesh runtime settings. One node and many nodes use the same runtime model.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "takod"
          ],
          "default": "takod",
          "description": "Runtime engine"
        },
        "proxy": {
          "type": "string",
          "enum": [
            "tako-proxy"
          ],
          "default": "tako-proxy",
          "description": "Built-in Caddy-backed ingress proxy"
        },
        "agent": {
          "type": "object",
          "description": "takod node-local reconciler settings",
          "properties": {
            "enabled": {
              "type": "boolean",
              "const": true,
              "default": true,
              "description": "Must be true; takod agent is required"
            },
            "socket": {
              "type": "string",
              "default": "/run/tako/takod.sock"
            },
            "dataDir": {
              "type": "string",
              "default": "/var/lib/tako"
            }
          }
        }
      }
    },
    "mesh": {
      "type": "object",
      "description": "Private WireGuard-style node mesh settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "const": true,
          "default": true,
          "description": "Must be true; single-node deploys use a one-node mesh"
        },
        "networkCIDR": {
          "type": "string",
          "default": "10.210.0.0/16"
        },
        "interface": {
          "type": "string",
          "default": "tako"
        },
        "listenPort": {
          "type": "integer",
          "default": 51820,
          "minimum": 1,
          "maximum": 65535
        },
        "subnetBits": {
          "type": "integer",
          "default": 24,
          "minimum": 8,
          "maximum": 30
        },
        "natTraversal": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "state": {
      "type": "object",
      "description": "Deployment state and reconciliation policy",
      "properties": {
        "backend": {
          "type": "string",
          "enum": [
            "replicated"
          ],
          "default": "replicated"
        },
        "deployConsistency": {
          "type": "string",
          "enum": [
            "lease"
          ],
          "default": "lease"
        },
        "onUnreachableNode": {
          "type": "string",
          "enum": [
            "block"
          ],
          "default": "block"
        },
        "remoteCacheEnabled": {
          "type": "boolean",
          "enum": [
            true
          ],
          "default": true
        }
      }
    },
    "registries": {
      "type": "object",
      "description": "Private image registry credentials keyed by host (e.g. ghcr.io). Passwords must be ${ENV_VAR} references; credentials are request-scoped and never persisted on nodes.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "Registry username. Use ${ENV_VAR}."
          },
          "password": {
            "type": "string",
            "description": "Registry password or token. Must be an ${ENV_VAR} reference."
          }
        },
        "required": ["username", "password"],
        "additionalProperties": false
      }
    },
    "servers": {
      "type": "object",
      "description": "Explicit SSH server connection details",
      "additionalProperties": {
        "type": "object",
        "required": [
          "host",
          "user"
        ],
        "properties": {
          "host": {
            "type": "string",
            "description": "Server IP or hostname"
          },
          "privateHost": {
            "type": "string",
            "description": "Private/LAN/VPN address used by `tako domains hosts` for internal proxy routes"
          },
          "user": {
            "type": "string",
            "description": "SSH user"
          },
          "port": {
            "type": "integer",
            "description": "SSH port",
            "default": 22
          },
          "sshKey": {
            "type": "string",
            "description": "Path to SSH private key"
          },
          "password": {
            "type": "string",
            "description": "SSH password (use env var)"
          },
          "labels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    "deployment": {
      "type": "object",
      "description": "Deployment optimization settings",
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "parallel",
            "sequential"
          ],
          "description": "Deployment strategy"
        },
        "parallel": {
          "type": "object",
          "properties": {
            "maxConcurrentBuilds": {
              "type": "integer",
              "default": 4
            },
            "maxConcurrentDeploys": {
              "type": "integer",
              "default": 4
            },
            "strategy": {
              "type": "string",
              "enum": [
                "dependency-aware",
                "resource-aware",
                "round-robin"
              ]
            }
          }
        },
        "cache": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "type": {
              "type": "string",
              "enum": [
                "local",
                "registry"
              ]
            },
            "retention": {
              "type": "string",
              "description": "Cache retention period (e.g., 7d)"
            }
          }
        },
        "build": {
          "type": "object",
          "description": "Where build-backed service images are produced before takod reconciles containers. remote keeps the current server-side build path. local builds with Docker buildx on the developer or CI machine and pushes to each assigned node through docker-pussh/unregistry. auto tries local first and falls back to remote.",
          "properties": {
            "strategy": {
              "type": "string",
              "enum": [
                "remote",
                "local",
                "auto"
              ],
              "default": "remote"
            }
          }
        }
      }
    },
    "notifications": {
      "type": "object",
      "description": "Deployment notification settings",
      "properties": {
        "slack": {
          "type": "string",
          "description": "Slack webhook URL"
        },
        "discord": {
          "type": "string",
          "description": "Discord webhook URL"
        },
        "webhook": {
          "type": "string",
          "description": "Generic webhook URL"
        }
      }
    },
    "volumes": {
      "type": "object",
      "description": "Named volume definitions",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "driver": {
            "type": "string",
            "default": "local"
          },
          "driver_opts": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "labels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "external": {
            "type": "boolean"
          },
          "name": {
            "type": "string"
          }
        }
      }
    },
    "environments": {
      "type": "object",
      "description": "Deployment environments",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "servers": {
            "type": "array",
            "description": "Server names for this environment",
            "items": {
              "type": "string"
            }
          },
          "proxy": {
            "type": "object",
            "description": "Environment-level proxy placement. Built-in public ACME TLS requires placement to resolve to one proxy node until distributed certificate handling is implemented.",
            "properties": {
              "placement": {
                "type": "object",
                "description": "Where proxy routes should be reconciled",
                "properties": {
                  "strategy": {
                    "type": "string",
                    "enum": [
                      "spread",
                      "pinned",
                      "any",
                      "global"
                    ]
                  },
                  "servers": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "constraints": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "acme": {
                "type": "object",
                "description": "Environment-scoped DNS-01 provider used by wildcard routes and routes with proxy.tls.challenge=dns. Credentials must be whole ${ENV_VAR} references and are persisted only on proxy nodes.",
                "additionalProperties": false,
                "required": ["dnsProvider", "credentials"],
                "properties": {
                  "dnsProvider": {
                    "type": "string",
                    "enum": ["cloudflare", "hetzner", "digitalocean"]
                  },
                  "credentials": {
                    "type": "object",
                    "description": "Provider credential values. apiToken is required; cloudflare also accepts optional zoneToken."
                  }
                },
                "allOf": [
                  {
                    "if": {
                      "properties": {"dnsProvider": {"const": "cloudflare"}},
                      "required": ["dnsProvider"]
                    },
                    "then": {
                      "properties": {
                        "credentials": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["apiToken"],
                          "properties": {
                            "apiToken": {"type": "string", "pattern": "^\\$\\{[A-Za-z_][A-Za-z0-9_]*\\}$"},
                            "zoneToken": {"type": "string", "pattern": "^\\$\\{[A-Za-z_][A-Za-z0-9_]*\\}$"}
                          }
                        }
                      }
                    },
                    "else": {
                      "properties": {
                        "credentials": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": ["apiToken"],
                          "properties": {
                            "apiToken": {"type": "string", "pattern": "^\\$\\{[A-Za-z_][A-Za-z0-9_]*\\}$"}
                          }
                        }
                      }
                    }
                  }
                ]
              }
            }
          },
          "services": {
            "type": "object",
            "description": "Services to deploy",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "build": {
                  "description": "Build context path or structured build options",
                  "oneOf": [
                    { "type": "string", "minLength": 1 },
                    {
                      "type": "object",
                      "required": ["context"],
                      "additionalProperties": false,
                      "properties": {
                        "context": { "type": "string", "minLength": 1 },
                        "args": {
                          "type": "object",
                          "maxProperties": 128,
                          "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
                          "additionalProperties": { "type": "string" }
                        },
                        "target": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$" }
                      }
                    }
                  ]
                },
                "image": {
                  "type": "string",
                  "description": "Docker image"
                },
                "imageFrom": {
                  "type": "string",
                  "description": "Reference a top-level shared build. For kind: run, this may instead reference another service, which becomes an implicit dependency."
                },
                "port": {
                  "type": "integer",
                  "description": "Container port"
                },
                "ports": {
                  "type": "array",
                  "description": "Raw TCP/UDP host ports published directly on the node, bypassing tako-proxy (\"PORT\", \"HOST:CONTAINER\", \"IP:HOST:CONTAINER\", optional /tcp or /udp). Requires deploy.strategy recreate and at most one replica.",
                  "items": {
                    "type": "string"
                  }
                },
                "command": {
                  "description": "Override container command. String form preserves Tako's legacy sh -c behavior; list form is passed as raw exec argv.",
                  "oneOf": [
                    { "type": "string", "minLength": 1 },
                    { "type": "array", "minItems": 1, "maxItems": 256, "items": { "type": "string" } }
                  ]
                },
                "entrypoint": {
                  "description": "Override the image entrypoint as a string executable or argv list.",
                  "oneOf": [
                    { "type": "string", "minLength": 1 },
                    { "type": "array", "minItems": 1, "maxItems": 256, "items": { "type": "string" } }
                  ]
                },
                "labels": {
                  "type": "object",
                  "description": "Custom container labels. Keys beginning with tako. are reserved.",
                  "maxProperties": 256,
                  "propertyNames": { "not": { "pattern": "^tako\\." } },
                  "additionalProperties": { "type": "string" }
                },
                "replicas": {
                  "type": "integer",
                  "default": 1,
                  "description": "Number of replicas"
                },
                "restart": {
                  "type": "string",
                  "enum": [
                    "no",
                    "on-failure",
                    "always",
                    "unless-stopped"
                  ],
                  "description": "Restart policy"
                },
                "env": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  },
                  "description": "Environment variables"
                },
                "envFile": {
                  "type": "string",
                  "description": "Path to .env file"
                },
                "envFiles": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 32,
                  "uniqueItems": true,
                  "items": { "type": "string", "minLength": 1 },
                  "description": "Ordered .env files; later files override earlier files"
                },
                "user": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                },
                "workingDir": {
                  "type": "string",
                  "pattern": "^/"
                },
                "stopGracePeriod": {
                  "type": "string",
                  "description": "Whole-second container stop timeout, for example 60s"
                },
                "init": {
                  "type": "boolean"
                },
                "extraHosts": {
                  "type": "array",
                  "maxItems": 128,
                  "uniqueItems": true,
                  "items": { "type": "string", "minLength": 3 }
                },
                "ulimits": {
                  "type": "object",
                  "maxProperties": 64,
                  "propertyNames": { "pattern": "^[a-z][a-z0-9_]{0,63}$" },
                  "additionalProperties": {
                    "oneOf": [
                      { "type": "integer", "minimum": 1 },
                      {
                        "type": "object",
                        "required": ["soft", "hard"],
                        "additionalProperties": false,
                        "properties": {
                          "soft": { "type": "integer", "minimum": 1 },
                          "hard": { "type": "integer", "minimum": 1 }
                        }
                      }
                    ]
                  }
                },
                "shmSize": {
                  "type": "string",
                  "pattern": "^[1-9][0-9]*([bBkKmMgG]|[kKmMgG][bB]|[kKmMgG][iI][bB])?$"
                },
                "secrets": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Secret names from .tako/secrets"
                },
                "volumes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Volume mounts"
                },
                "files": {
                  "type": "array",
                  "maxItems": 128,
                  "description": "Local regular files or directories distributed through takod and mounted read-only into the container.",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["source", "target"],
                    "properties": {
                      "source": { "type": "string", "minLength": 1 },
                      "target": { "type": "string", "pattern": "^/", "minLength": 2 },
                      "secret": { "type": "boolean", "description": "Force private 0700/0600 modes for the distributed tree." },
                      "owner": { "type": "string", "pattern": "^[0-9]+(:[0-9]+)?$", "description": "Numeric uid or uid:gid that owns the published tree; defaults to a numeric service user or root." }
                    }
                  }
                },
                "backup": {
                  "type": "object",
                  "description": "Optional takod-managed periodic backups for named service volumes. Backups are created node-locally and can also be uploaded to S3-compatible object storage.",
                  "required": [
                    "schedule"
                  ],
                  "properties": {
                    "schedule": {
                      "type": "string",
                      "description": "Cron schedule, for example 0 2 * * * or @daily"
                    },
                    "retain": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 3660,
                      "default": 7,
                      "description": "Days to retain local and object-storage backups"
                    },
                    "volumes": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Optional logical service volume names to back up. Omit to back up every named volume on the service."
                    },
                    "storage": {
                      "type": "object",
                      "description": "Optional S3-compatible object storage target for off-node backup copies",
                      "properties": {
                        "provider": {
                          "type": "string",
                          "enum": [
                            "s3",
                            "r2",
                            "s3-compatible"
                          ],
                          "default": "s3"
                        },
                        "bucket": {
                          "type": "string"
                        },
                        "region": {
                          "type": "string",
                          "description": "AWS region or auto for Cloudflare R2"
                        },
                        "endpoint": {
                          "type": "string",
                          "description": "Required for r2 and s3-compatible providers"
                        },
                        "prefix": {
                          "type": "string",
                          "description": "Optional object key prefix"
                        },
                        "accessKeyId": {
                          "type": "string",
                          "description": "Use an environment variable such as ${TAKO_BACKUP_ACCESS_KEY_ID}"
                        },
                        "secretAccessKey": {
                          "type": "string",
                          "description": "Use an environment variable such as ${TAKO_BACKUP_SECRET_ACCESS_KEY}"
                        },
                        "sessionToken": {
                          "type": "string"
                        },
                        "forcePathStyle": {
                          "type": "boolean",
                          "description": "Enable for MinIO and some S3-compatible stores"
                        }
                      }
                    }
                  }
                },
                "persistent": {
                  "type": "boolean",
                  "description": "Mark as stateful/persistent. Requires at least one volume, and multi-node environments require pinned or global placement."
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "service",
                    "job",
                    "run"
                  ],
                  "description": "Workload kind: service (default), job (cron schedule), or run (fingerprinted deploy-time run-to-completion step)."
                },
                "schedule": {
                  "type": "string",
                  "description": "kind: job only. Cron expression (five fields or descriptors like @hourly), evaluated in UTC unless timezone is set."
                },
                "timezone": {
                  "type": "string",
                  "description": "kind: job only. IANA timezone the schedule is evaluated in (e.g. Asia/Manila)."
                },
                "timeout": {
                  "type": "string",
                  "description": "kind: job or kind: run only. Duration such as 30m to kill an execution after (default 1h)."
                },
                "resources": {
                  "type": "object",
                  "description": "Container runtime resource limits",
                  "properties": {
                    "memory": {
                      "type": "string",
                      "pattern": "^[1-9][0-9]*([bBkKmMgG]|[kKmMgG][bB]|[kKmMgG][iI][bB])?$",
                      "description": "Docker memory limit passed as --memory, for example 512m or 1g"
                    },
                    "cpus": {
                      "type": "string",
                      "pattern": "^[0-9]+(\\.[0-9]+)?$",
                      "description": "Docker CPU limit passed as --cpus, for example 0.5 or 2"
                    }
                  }
                },
                "dependsOn": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Service dependencies"
                },
                "proxy": {
                  "type": "object",
                  "description": "Proxy settings. Public routes use ACME-backed HTTPS; internal routes are HTTP-only private-network routes.",
                  "properties": {
                    "visibility": {
                      "type": "string",
                      "enum": [
                        "public",
                        "internal"
                      ],
                      "default": "public",
                      "description": "Use public for DNS/ACME ingress or internal for private-network HTTP ingress"
                    },
                    "domain": {
                      "type": "string",
                      "description": "Primary public hostname. Wildcards require environment proxy.acme and use DNS-01."
                    },
                    "host": {
                      "type": "string",
                      "description": "Internal hostname for proxy.visibility=internal. Defaults to <service>.<environment>.<project>.tako.internal."
                    },
                    "domains": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Additional co-equal serving hostnames beside domain. Each serves the same upstreams with its own certificate; domain stays the primary for URLs and redirects."
                    },
                    "redirectFrom": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Hostnames to redirect from. Wildcard hostnames are not supported by the built-in proxy yet."
                    },
                    "email": {
                      "type": "string",
                      "description": "Let's Encrypt email"
                    },
                    "basicAuth": {
                      "type": "object",
                      "description": "HTTP basic authentication enforced at the proxy for every route of this service.",
                      "properties": {
                        "username": {
                          "type": "string",
                          "pattern": "^[A-Za-z0-9._@-]+$",
                          "maxLength": 64,
                          "description": "Basic auth username"
                        },
                        "passwordBcrypt": {
                          "type": "string",
                          "description": "Pre-computed bcrypt hash of the password (never the plaintext). Mint one with `tako proxy hash-password`."
                        }
                      },
                      "required": [
                        "username",
                        "passwordBcrypt"
                      ]
                    },
                    "allowIps": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "Client IPs/CIDRs allowed to reach this service through the proxy; all others get 403. Matches the TCP peer unless trustedProxies is configured, then matches the parsed client IP."
                    },
                    "trustedProxies": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "pattern": "^[^/]+/[0-9]+$"
                      },
                      "description": "Explicit proxy/CDN CIDRs whose forwarded client IP headers may be trusted. IPv4 prefixes broader than /8 and IPv6 prefixes broader than /24 are rejected. All routes sharing a proxy node must use the same nonempty set."
                    },
                    "tls": {
                      "type": "object",
                      "properties": {
                        "mode": {
                          "type": "string",
                          "enum": [
                            "auto",
                            "off"
                          ],
                          "description": "auto for public ACME-backed routes; off for internal HTTP-only routes"
                        },
                        "provider": {
                          "type": "string",
                          "enum": [
                            "letsencrypt",
                            "zerossl"
                          ]
                        },
                        "staging": {
                          "type": "boolean"
                        },
                        "challenge": {
                          "type": "string",
                          "enum": ["auto", "dns"],
                          "description": "dns opts explicit hostnames into takod-managed DNS-01. Wildcard hostnames imply dns."
                        }
                      }
                    },
                    "dynamicDomains": {
                      "type": "object",
                      "description": "Optional Caddy on-demand TLS domain authority. ask uses <service>:<path> and is called before certificates are issued for generated/custom domains. The ask endpoint must approve only exact domains owned by this app/environment.",
                      "properties": {
                        "enabled": {
                          "type": "boolean",
                          "default": true
                        },
                        "ask": {
                          "type": "string",
                          "description": "Internal ask endpoint reference, for example admin:/api/domains/authorize"
                        }
                      }
                    }
                  }
                },
                "healthCheck": {
                  "type": "object",
                  "description": "Health check configuration",
                  "properties": {
                    "command": {
                      "type": "string",
                      "maxLength": 4096,
                      "description": "Docker health command (mutually exclusive with path and tcpPort)."
                    },
                    "path": {
                      "type": "string"
                    },
                    "tcpPort": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535
                    },
                    "interval": {
                      "type": "string"
                    },
                    "timeout": {
                      "type": "string"
                    },
                    "retries": {
                      "type": "integer"
                    },
                    "startPeriod": {
                      "type": "string"
                    }
                  },
                  "allOf": [
                    { "not": { "required": ["command", "path"] } },
                    { "not": { "required": ["command", "tcpPort"] } },
                    { "not": { "required": ["path", "tcpPort"] } }
                  ]
                },
                "deploy": {
                  "type": "object",
                  "description": "Deployment strategy for takod reconciliation. recreate is the conservative default. rolling warms a full replacement revision, waits for readiness, switches proxy routes, then prunes stale revisions. blue_green warms a full green revision for stateless public services, waits for readiness and optional smoke tests, and switches proxy routes only after checks pass. Default automatic promotion switches during deploy; promotion: manual warms green for a later tako promote <service>. deploy.gracePeriod can retain the previous blue-green revision after promotion before stale revision cleanup.",
                  "properties": {
                    "strategy": {
                      "type": "string",
                      "enum": [
                        "recreate",
                        "rolling",
                        "blue_green"
                      ]
                    },
                    "maxUnavailable": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "maxSurge": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "rollbackOnFailure": {
                      "type": "boolean"
                    },
                    "readiness": {
                      "type": "object",
                      "properties": {
                        "path": {
                          "type": "string"
                        },
                        "tcpPort": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 65535
                        },
                        "timeout": {
                          "type": "string"
                        },
                        "interval": {
                          "type": "string"
                        },
                        "retries": {
                          "type": "integer",
                          "minimum": 0
                        }
                      }
                    },
                    "smokeTest": {
                      "type": "object",
                      "properties": {
                        "path": {
                          "type": "string"
                        },
                        "expectedStatus": {
                          "type": "integer",
                          "minimum": 100,
                          "maximum": 599
                        }
                      }
                    },
                    "promotion": {
                      "type": "string",
                      "enum": [
                        "automatic",
                        "manual"
                      ]
                    },
                    "gracePeriod": {
                      "type": "string",
                      "description": "blue_green only. Duration such as 30s or 2m to keep the previous revision running after proxy promotion before stale revision cleanup."
                    },
                    "release": {
                      "type": "object",
                      "description": "Release command run from the new image exactly once per deploy, before traffic cutover; a non-zero exit aborts the rollout.",
                      "properties": {
                        "command": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "minItems": 1,
                          "description": "Command and arguments, e.g. [\"php\", \"artisan\", \"migrate\", \"--force\"]."
                        },
                        "timeout": {
                          "type": "string",
                          "description": "Duration such as 5m to kill the release command after (default 5m)."
                        },
                        "volumes": {
                          "type": "boolean",
                          "description": "Mount the service's volumes into the release container (default false)."
                        }
                      },
                      "required": [
                        "command"
                      ],
                      "additionalProperties": false
                    }
                  }
                },
                "placement": {
                  "type": "object",
                  "description": "Placement configuration",
                  "properties": {
                    "strategy": {
                      "type": "string",
                      "enum": [
                        "spread",
                        "pinned",
                        "any",
                        "global"
                      ]
                    },
                    "servers": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "constraints": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "loadBalancer": {
                  "type": "object",
                  "description": "Load balancer settings",
                  "properties": {
                    "strategy": {
                      "type": "string",
                      "enum": [
                        "round_robin",
                        "sticky"
                      ]
                    }
                  }
                },
                "export": {
                  "type": "boolean",
                  "description": "Attach this service to a service-scoped export network for other projects"
                },
                "imports": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Import services from other projects as project.service in the same environment"
                }
              },
              "allOf": [
                { "not": { "required": ["envFile", "envFiles"] } }
              ]
            }
          }
        }
      }
    }
  }
}
